obj-y += astra.o \
         astra_uart.o \
         uart_framing.o \
         crtp_uart2_bridge.o \
         cobs.o \
         crc16.o \

# Standards & Base Warnings
ccflags-y += -std=gnu11 -O2 \
             -Wall -Wextra -Wpedantic -Werror

# Security & Safety Warnings
ccflags-y += -Wconversion \
             -Wshadow \
             -Wnull-dereference \
             -Wformat=2 -Wformat-security \
             -Wdouble-promotion \
             -Wundef \
             -Wunused-result \
             -Wlogical-op \
             -Wcast-qual \
             -Wcast-align

# Optimization Flags
ccflags-y += -fstack-usage \
             -fno-common \
             -fstack-protector-strong
